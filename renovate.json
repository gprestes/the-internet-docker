{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "lockFileMaintenance": {
        "enabled": true,
        "extends": [
            "schedule:daily"
        ]
    },
    "separateMajorMinor": true,
    "separateMultipleMajor": true,
    "separateMultipleMinor": true,
    "separateMinorPatch": true,
    "extends": [
        "config:recommended"
    ]
}
